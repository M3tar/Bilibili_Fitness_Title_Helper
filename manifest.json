{
  "manifest_version": 3,
  "name": "B站健身视频标题生成器",
  "version": "1.7",
  "description": "自动生成B站健身视频标题",
  "permissions": ["clipboardWrite", "tabs"],
  "host_permissions": ["https://member.bilibili.com/*"],
  "web_accessible_resources": [
    {
      "resources": ["covers/*.jpg", "covers/*.png"],
      "matches": ["https://member.bilibili.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.svg",
      "48": "images/icon48.svg",
      "128": "images/icon128.svg"
    }
  },
  "icons": {
    "16": "images/icon16.svg",
    "48": "images/icon48.svg",
    "128": "images/icon128.svg"
  },
  "content_scripts": [
    {
      "matches": ["https://member.bilibili.com/platform/upload/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self'"
  }
} 
